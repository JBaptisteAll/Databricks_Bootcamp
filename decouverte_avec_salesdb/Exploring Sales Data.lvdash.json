{
  "datasets": [
    {
      "name": "dd369e28",
      "displayName": "Customer Insights Summary Report",
      "queryLines": [
        "SELECT\r\n",
        "  COUNT(c.customer_id) AS Total_customers,\r\n",
        "  SUM(sales_amount) AS Total_sales,\r\n",
        "  SUM(quantity) AS Total_quantity,\r\n",
        "  COUNT(DISTINCT(order_number)) AS Total_orders\r\n",
        "FROM workspace.salesdb.fact_sales AS s\r\n",
        "JOIN workspace.salesdb.dim_customers AS c USING (customer_key)\r\n",
        "JOIN workspace.salesdb.dim_products AS p USING (product_key)"
      ]
    },
    {
      "name": "98d29f35",
      "displayName": "Monthly Sales and Order Volume Summary",
      "queryLines": [
        "-- Orders over time\n",
        "SELECT\n",
        "  date_trunc('month', order_date) AS order_month,\n",
        "  COUNT(DISTINCT(order_number)) AS total_nb_order,\n",
        "  SUM(sales_amount) AS total_sale\n",
        "FROM workspace.salesdb.fact_sales\n",
        "GROUP BY date_trunc('month', order_date)"
      ]
    },
    {
      "name": "7d6f8cac",
      "displayName": "Category Sales Summary Report",
      "queryLines": [
        "-- Sales by category\n",
        "SELECT\n",
        "  p.category,\n",
        "  SUM(s.sales_amount)\n",
        "FROM workspace.salesdb.fact_sales AS s\n",
        "INNER JOIN workspace.salesdb.dim_products AS p USING (product_key)\n",
        "GROUP BY p.category"
      ],
      "catalog": "workspace",
      "schema": "salesdb"
    },
    {
      "name": "2cf6a159",
      "displayName": "all_joins",
      "queryLines": [
        "SELECT\r\n",
        "  *,\r\n",
        "  CONCAT(first_name, ' ', last_name) AS fullname\r\n",
        "FROM workspace.salesdb.fact_sales AS s\r\n",
        "JOIN workspace.salesdb.dim_customers AS c USING (customer_key)\r\n",
        "JOIN workspace.salesdb.dim_products AS p USING (product_key)"
      ]
    }
  ],
